{
  "name": "fingerbrow",
  "private": false,
  "version": "0.1.0",
  "description": "Open-source, self-hosted browser fingerprint profile manager.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:linux": "tauri build --bundles appimage,deb",
    "desktop:build:mac": "tauri build --bundles app,dmg",
    "docker:linux-build": "docker compose run --rm linux-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.0.4"
  }
}
